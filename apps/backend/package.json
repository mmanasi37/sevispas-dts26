    "@babel/core": "^7.29.0",
    "@babel/preset-flow": "^7.27.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.20.0",
    "babel-plugin-syntax-hermes-parser": "^0.36.0",
