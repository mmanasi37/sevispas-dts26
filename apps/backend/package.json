{
  "name": "sevispass",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "private": true,
  "type": "module",
  "main": "build/app.js",
  "scripts": {
    "dev": "nodemon --exec tsx src/app.ts",
    "build": "npm run clean && tsc && tsc-alias",
    "build:watch": "npm run clean && tsc --watch && tsc-alias",
    "clean": "rimraf build",
    "start": "pm2 start pm2.config.js",
    "remove": "pm2 delete pm2.config.js",
    "restart": "pm2 restart pm2.config.js --update-env",
    "stop": "pm2 stop pm2.config.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "test:unit": "node test tests/unit",
    "test:integration": "node test tests/integration",
    "test:e2e": "node test tests/e2e",
    "test:load": "k6 test/load-test.ts",
    "db:migrate:up": "pnpm run -r dotenv/config ./src/database/migrate latest",
    "db:migrate:down": "pnpm run -r dotenv/config ./src/database/migrate down",
    "db:migrate:create": "pnpm run -r dotenv/config ./src/database/migrate create initial",
    "db:generate:types": "pnpm dlx kysely-codegen --out-file=src/database/schema.ts"
  },
  "dependencies": {
    "@bull-board/api": "^7.2.1",
    "@bull-board/express": "^7.2.1",
    "@libsql/client": "0.8.1",
    "@libsql/kysely-libsql": "0.4.1",
    "@sliderzz/typify": "^1.3.2",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "connect-timeout": "^1.9.1",
    "cookie-parser": "~1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "debug": "~2.6.9",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "http-errors": "~1.6.3",
    "jsonwebtoken": "^9.0.3",
    "kysely": "^0.29.3",
    "kysely-migration-cli": "^0.4.2",
    "morgan": "^1.11.0",
    "node-fetch": "^2.7.0",
    "pg": "^8.22.0",
    "supertest": "^7.2.2",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/preset-flow": "^7.29.7",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.1",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.20.0",
    "babel-plugin-syntax-hermes-parser": "^0.36.1",
    "jest": "^29.7.0",
    "kysely-codegen": "^0.20.0",
    "kysely-ctl": "^0.21.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.9.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}