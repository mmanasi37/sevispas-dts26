{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "rewriteRelativeImportExtensions": true,
    "erasableSyntaxOnly": false,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "paths": {
      "#/*": ["./src/*"]
    },
    "types": ["node", "express", "express-session", "./src/types.d.ts"]
  },
  "include": ["src/**/*"]
}
