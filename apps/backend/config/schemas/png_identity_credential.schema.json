{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.sevis.gov.pg/PNGCitizenIdentity-v1.json",
    "title": "PNG Citizen Identity Credential",
    "description": "W3C Verifiable Credential for PNG Citizens, compliant with SevisPNG standards",
    "type": "object",
    "required": [
        "@context",
        "type",
        "issuer",
        "issuanceDate",
        "credentialSubject"
    ],
    "properties": {
        "@context": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "https://www.w3.org/ns/credentials/v2",
                    "https://schemas.sevis.gov.pg/contexts/png-identity-v1.jsonld"
                ]
            },
            "minItems": 2,
            "uniqueItems": true
        },
        "type": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "VerifiableCredential",
                    "PNGCitizenIdentityCredential"
                ]
            },
            "minItems": 2,
            "uniqueItems": true
        },
        "issuer": {
            "type": "object",
            "required": [
                "id"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uri"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "issuanceDate": {
            "type": "string",
            "format": "date-time"
        },
        "expirationDate": {
            "type": "string",
            "format": "date-time"
        },
        "credentialSubject": {
            "type": "object",
            "required": [
                "id",
                "name",
                "birthDate",
                "nationality"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^did:sevispng:citizen:[a-z0-9_]+$"
                },
                "name": {
                    "type": "string",
                    "minLength": 2
                },
                "birthDate": {
                    "type": "string",
                    "format": "date"
                },
                "birthPlace": {
                    "type": "string"
                },
                "nationality": {
                    "type": "string",
                    "pattern": "^[A-Z]{2}$"
                }
            },
            "additionalProperties": false
        },
        "credentialStatus": {
            "type": "object",
            "required": [
                "id",
                "type"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uri"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "RevocationList2021Status"
                    ]
                },
                "statusListIndex": {
                    "type": "integer",
                    "minimum": 0
                },
                "statusListCredential": {
                    "type": "string",
                    "format": "uri"
                }
            }
        }
    },
    "additionalProperties": false
}